{
  "name": "@unleash/openfeature-node-provider",
  "version": "0.1.0",
  "description": "OpenFeature provider for the Unleash Node.js server-side SDK",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Unleash/unleash-js-openfeature-provider.git"
  },
  "keywords": [
    "unleash",
    "openfeature",
    "feature-flags",
    "feature-toggles",
    "provider"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@openfeature/server-sdk": "^1.14.0",
    "unleash-client": "^6.0.0"
  },
  "devDependencies": {
    "@openfeature/server-sdk": "^1.19.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "unleash-client": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
